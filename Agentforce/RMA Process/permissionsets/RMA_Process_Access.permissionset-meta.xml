<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to the RMA Process Visualforce page and Apex classes required by the Agentforce RMA action. Assign to the Agent User and any user who runs the RMA flow.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>RMA Process Access</label>
    <license>Salesforce</license>
    <classAccesses>
        <apexClass>RMAGeneratorController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>RMAGeneratorFlowAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>RMATemplateController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <pageAccesses>
        <apexPage>RMATemplate</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
</PermissionSet>
